# Copy to .env and fill in. .env is gitignored.
#
# You don't even need this file to try the dashboard: with no credentials the
# collector runs in DEMO mode (synthetic data). Add credentials below for real
# data from your mower.

# --- Husqvarna Developer Portal (https://developer.husqvarnagroup.cloud) ---
# Create an Application, connect the Authentication API + Automower Connect API,
# then copy its Application key / secret here. Leave blank to stay in DEMO mode.
HUSQVARNA_CLIENT_ID=your-application-key
HUSQVARNA_CLIENT_SECRET=your-application-secret

# Force demo mode even when credentials are present (set to true to try the UI).
DEMO_MODE=

# --- InfluxDB ---
# Token is shared by InfluxDB (admin), the collector, and Grafana. Generate a
# random one, e.g.:  openssl rand -hex 32
INFLUXDB_TOKEN=change-me-to-a-long-random-string
INFLUXDB_PASSWORD=change-me
INFLUXDB_ORG=automower
INFLUXDB_BUCKET=automower
INFLUXDB_USERNAME=admin
# Retention: 0s = keep forever. Or e.g. 730d for two years.
INFLUXDB_RETENTION=0s
INFLUXDB_PORT=8086

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
GRAFANA_PORT=3005

# --- Collector tuning ---
# Seconds between REST polls (refreshes statistics + resyncs). WebSocket handles
# real-time state, so this can be infrequent. Free API quota is generous for
# hourly polls.
REST_POLL_INTERVAL=3600
# Set false to skip storing GPS positions.
WRITE_POSITIONS=true
LOG_LEVEL=INFO

# --- Image (optional) ---
# By default the stack PULLS the published multi-arch image, so no build is
# needed. Override to pin a specific version (recommended for stability) or to
# use your own fork's image:
# COLLECTOR_IMAGE=ghcr.io/robertobasile84/automower-collector:0.1.0
#
# Developers: to build from your local source instead, use the dev overlay:
#   docker compose -f compose.yaml -f compose.dev.yaml up -d --build
